# MongoDB
MONGO_URI=mongodb://localhost:27017/ibbi_local

# JWT
JWT_SECRET=TROCAR_POR_UM_SEGREDO_FORTE_ALEATORIO
JWT_EXPIRES_IN=7d

# Senha padrão para novos usuários
DEFAULT_USER_PASSWORD=TROCAR_SENHA_PADRAO

# Senha do usuário master (seed)
SEED_MASTER_PASSWORD=TROCAR_SENHA_MASTER

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.exemplo.com
EVOLUTION_INSTANCE=SuaInstancia
EVOLUTION_API_KEY=TROCAR_POR_SUA_API_KEY
EVOLUTION_ALLOW_SELF_SIGNED=false

# WhatsApp destino (pedidos de oração)
CHURCH_WHATSAPP_NUMBER=5500000000000

# Mock WhatsApp destino (dev)
MOCK_WHATSAPP_NUMBER=5500000000000
FORCE_MOCK_RECIPIENT=true

# reCAPTCHA v3 (opcional — se não configurado, login funciona sem captcha)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Frontend (adicionar no .env do Vite)
# VITE_RECAPTCHA_SITE_KEY=

# Email (SMTP) — para alertas do monitor Evolution API
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=IBBI Sistema <seu-email@gmail.com>
ALERT_EMAIL=isaiasilva.info@gmail.com

# Monitor Evolution API (cron — padrão: a cada 5 minutos)
# EVOLUTION_MONITOR_CRON=*/5 * * * *

# Servidor
PORT=3001
NODE_ENV=development
